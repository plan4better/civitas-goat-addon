# /home/p4b/civitas-goat-addon/templates/goat-values.yaml.j2
# Rendered by 03_helm_install.yml and passed to `helm install` as a values file.

global:
  # inv_k8s.storage_class is a DICT in civitas-core ({loc, rwo, rwx}); the
  # chart wants a string. Pick `loc` (local, single-node) by default — works
  # for k3d and local clusters.
  storageClass: "{{ inv_k8s.storage_class.loc | default('local-path') }}"
  imagePullSecrets: []
  commonLabels:
    civitas.core/owner: goat-addon
    civitas.core/env: "{{ ENVIRONMENT }}"

core:
  enabled: true
  ingress:
    enabled: false       # civitas exposes via APISIX (see 04_apisix_routes.yml)
  auth:
    enabled: true
    existingSecret: goat-keycloak-creds   # created by 02_keycloak_client.yml

web:
  enabled: true
  auth:
    enabled: true
    existingSecret: goat-keycloak-creds
    publicUrl: "{{ goat_addon.web.public_url }}"

postgresql:
  operator:
    enabled: false       # civitas has Zalando operator cluster-wide
  cluster:
    enabled: false
  external:
    host: "{{ goat_addon.db.central_db_name }}.{{ goat_addon.db.central_db_ns }}.svc.cluster.local"
    port: 5432
    database: "{{ goat_addon.db.name }}"
    existingSecret: goat-postgres-creds
    existingSecretUserKey: username
    existingSecretPasswordKey: password
    sslMode: prefer

redis:
  enabled: true          # bundled — light dep, fine inside civitas

# Windmill stays off in civitas Phase 2 (no demand yet, and would need its
# own Postgres user provisioning + APISIX routes).
windmill:
  server:
    enabled: false
  workers:
    default:
      enabled: false

caddy:
  enabled: false         # civitas's APISIX handles routing for custom domains
